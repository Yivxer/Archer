# Archer environment variables (optional)
# If you prefer not to put your API key in archer.toml,
# set it here and Archer will pick it up automatically.
#
# Copy this file to .env — it is gitignored.

# Your LLM API key (DeepSeek / OpenAI / any compatible provider)
ARCHER_API_KEY=sk-your-api-key-here

# Override the API base URL (optional)
# ARCHER_BASE_URL=https://api.openai.com/v1

# Override the model (optional)
# ARCHER_MODEL=deepseek-chat
